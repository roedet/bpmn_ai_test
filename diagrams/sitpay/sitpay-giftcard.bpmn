        <bpmndi:BPMNLabel><omgdc:Bounds x="966" y="545" width="68" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_B1_di" bpmnElement="Flow_B1"><omgdi:waypoint x="238" y="520"/><omgdi:waypoint x="290" y="520"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B2_di" bpmnElement="Flow_B2"><omgdi:waypoint x="410" y="520"/><omgdi:waypoint x="460" y="520"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B3_di" bpmnElement="Flow_B3"><omgdi:waypoint x="580" y="520"/><omgdi:waypoint x="630" y="520"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B4_di" bpmnElement="Flow_B4"><omgdi:waypoint x="750" y="520"/><omgdi:waypoint x="800" y="520"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B5_di" bpmnElement="Flow_B5"><omgdi:waypoint x="920" y="520"/><omgdi:waypoint x="982" y="520"/></bpmndi:BPMNEdge>

      <!-- EOD Batch row y=620 -->
      <bpmndi:BPMNShape id="Start_EOD_di" bpmnElement="Start_EOD">
