      <bpmndi:BPMNEdge id="Flow_E1_di" bpmnElement="Flow_E1"><omgdi:waypoint x="238" y="635"/><omgdi:waypoint x="290" y="635"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_di" bpmnElement="Flow_E2"><omgdi:waypoint x="440" y="635"/><omgdi:waypoint x="502" y="635"/></bpmndi:BPMNEdge>

      <!-- ═══ POOL: Gift Card API / CPI ═══ -->
      <bpmndi:BPMNShape id="Participant_GiftAPI_di" bpmnElement="Participant_GiftAPI" isHorizontal="true">
