      </bpmndi:BPMNEdge>
      <!-- Activate: Charge out/back -->
      <bpmndi:BPMNEdge id="MF_ChargeOut_di" bpmnElement="MF_ChargeOut">
        <omgdi:waypoint x="1030" y="160"/><omgdi:waypoint x="1030" y="730"/><omgdi:waypoint x="1010" y="730"/><omgdi:waypoint x="1010" y="750"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_ChargeBack_di" bpmnElement="MF_ChargeBack">
        <omgdi:waypoint x="1180" y="750"/><omgdi:waypoint x="1180" y="730"/><omgdi:waypoint x="1200" y="730"/><omgdi:waypoint x="1200" y="160"/>
      </bpmndi:BPMNEdge>
      <!-- Payment: Inquiry out/back -->
      <bpmndi:BPMNEdge id="MF_PayInqOut_di" bpmnElement="MF_PayInqOut">
