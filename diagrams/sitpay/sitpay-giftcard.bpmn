      <bpmndi:BPMNEdge id="Flow_G2_di" bpmnElement="Flow_G2"><omgdi:waypoint x="1070" y="790"/><omgdi:waypoint x="1120" y="790"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_G3_di" bpmnElement="Flow_G3"><omgdi:waypoint x="900" y="910"/><omgdi:waypoint x="950" y="910"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_G4_di" bpmnElement="Flow_G4"><omgdi:waypoint x="1240" y="910"/><omgdi:waypoint x="1290" y="910"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_G5_di" bpmnElement="Flow_G5"><omgdi:waypoint x="1520" y="870"/><omgdi:waypoint x="1520" y="830"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_G6_di" bpmnElement="Flow_G6"><omgdi:waypoint x="560" y="910"/><omgdi:waypoint x="610" y="910"/></bpmndi:BPMNEdge>

      <!-- ═══ POOL: SIT-Pay ═══ -->
