      </bpmndi:BPMNEdge>
      <!-- Payment: Redeem out/back -->
      <bpmndi:BPMNEdge id="MF_RedeemOut_di" bpmnElement="MF_RedeemOut">
        <omgdi:waypoint x="1200" y="310"/><omgdi:waypoint x="1200" y="730"/><omgdi:waypoint x="1180" y="730"/><omgdi:waypoint x="1180" y="870"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_RedeemBack_di" bpmnElement="MF_RedeemBack">
        <omgdi:waypoint x="1350" y="870"/><omgdi:waypoint x="1350" y="730"/><omgdi:waypoint x="1370" y="730"/><omgdi:waypoint x="1370" y="310"/>
      </bpmndi:BPMNEdge>
      <!-- Cancel: UndoRedeem out/back -->
      <bpmndi:BPMNEdge id="MF_UndoOut_di" bpmnElement="MF_UndoOut">
        <omgdi:waypoint x="1520" y="370"/><omgdi:waypoint x="1520" y="870"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_UndoBack_di" bpmnElement="MF_UndoBack">
