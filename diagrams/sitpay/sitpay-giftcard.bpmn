        <bpmndi:BPMNLabel><omgdc:Bounds x="1302" y="515" width="76" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- UC2+3 flows -->
      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1"><omgdi:waypoint x="238" y="270"/><omgdi:waypoint x="290" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2"><omgdi:waypoint x="410" y="270"/><omgdi:waypoint x="460" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P3_di" bpmnElement="Flow_P3"><omgdi:waypoint x="580" y="270"/><omgdi:waypoint x="630" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P4_di" bpmnElement="Flow_P4"><omgdi:waypoint x="750" y="270"/><omgdi:waypoint x="800" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P5_di" bpmnElement="Flow_P5"><omgdi:waypoint x="920" y="270"/><omgdi:waypoint x="970" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P6_di" bpmnElement="Flow_P6"><omgdi:waypoint x="1090" y="270"/><omgdi:waypoint x="1140" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P7_di" bpmnElement="Flow_P7"><omgdi:waypoint x="1260" y="270"/><omgdi:waypoint x="1310" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P8_di" bpmnElement="Flow_P8"><omgdi:waypoint x="1430" y="270"/><omgdi:waypoint x="1485" y="270"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P9_cancel_di" bpmnElement="Flow_P9_cancel">
