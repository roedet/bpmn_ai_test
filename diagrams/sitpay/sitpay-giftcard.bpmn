      <bpmndi:BPMNShape id="Task_SP_CancelProcess_di" bpmnElement="Task_SP_CancelProcess">
        <omgdc:Bounds x="1430" y="1190" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- ═══ MESSAGE FLOWS ═══ -->
      <!-- Activate: Inquiry out/back -->
      <bpmndi:BPMNEdge id="MF_InquiryOut_di" bpmnElement="MF_InquiryOut">
        <omgdi:waypoint x="520" y="160"/><omgdi:waypoint x="520" y="730"/><omgdi:waypoint x="500" y="730"/><omgdi:waypoint x="500" y="750"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF_InquiryBack_di" bpmnElement="MF_InquiryBack">
